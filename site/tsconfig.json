{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@mcpstack/docs": ["../src/index.ts"],
      "@mcpstack/docs/*": ["../src/*"],
      "@mcpstack/docs/styles.css": ["../src/styles.css"]
    },
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
