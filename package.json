{
  "name": "@emcy/docs",
  "version": "0.1.0",
  "description": "App Router-native MDX documentation for Next.js with reusable layouts, search, TOC, and locale-aware routing.",
  "type": "module",
  "main": "dist/index.js",
  "style": "styles.css",
  "types": "dist/index.d.ts",
  "sideEffects": [
    "./styles.css",
    "./dist/styles.css"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./theme": {
      "import": "./dist/theme.js",
      "types": "./dist/theme.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./styles.css": "./styles.css",
    "./src/styles.css": "./src/styles.css"
  },
  "files": [
    "dist",
    "styles.css",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:lib",
    "build:lib": "rm -rf dist && tsc -p tsconfig.build.json && cp src/styles.css dist/styles.css",
    "build:site": "npm run build:lib && next build ./site",
    "dev": "npm run build:lib && concurrently -k \"npm run dev:lib\" \"npm run dev:site\"",
    "dev:lib": "tsc -p tsconfig.build.json --watch",
    "dev:site": "next dev ./site --port 4003",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p ./site/tsconfig.json --noEmit",
    "prepare": "npm run build:lib",
    "prepublishOnly": "npm run lint && npm run test && npm run build:lib"
  },
  "keywords": [
    "docs",
    "documentation",
    "mdx",
    "nextjs",
    "next",
    "react",
    "search",
    "i18n",
    "seo",
    "saas",
    "emcy"
  ],
  "author": "Emcy <hello@emcy.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ross-slaney/emcydocs.git"
  },
  "bugs": {
    "url": "https://github.com/ross-slaney/emcydocs/issues"
  },
  "homepage": "https://github.com/ross-slaney/emcydocs",
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "next": ">=15.5.0 <17.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.7.0",
    "mermaid": "^11.14.0",
    "next-mdx-remote": "^6.0.0",
    "rehype-pretty-code": "^0.14.3",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.12",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.18.8",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.37.0",
    "eslint-config-next": "^16.1.6",
    "happy-dom": "^17.0.0",
    "next": "^16.1.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
